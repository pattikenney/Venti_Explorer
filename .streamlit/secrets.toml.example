# Copy this file to `.streamlit/secrets.toml` (same folder) and fill in real values.
# Never commit `secrets.toml` to git.

[passwords]
admin = "choose-a-strong-admin-password"
guest = "choose-a-guest-password"

[auth]
cookie_name = "research_audio_gallery"
cookie_key = "replace-with-a-long-random-string"
cookie_expiry_days = 7
